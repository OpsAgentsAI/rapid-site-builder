# Vertex AI Agent Engine running the builder crew (deploy one with
# scripts/deploy_agent_engine.py, then paste the resource name here).
AGENT_ENGINE_RESOURCE=projects/YOUR_PROJECT/locations/us-central1/reasoningEngines/YOUR_ENGINE_ID

# GCS bucket (public-read) caching Gemini-generated hero images.
SITE_IMAGES_BUCKET=your-site-images-bucket
# GCS bucket (private) holding published sites served at /sites/:id.
PUBLISHED_SITES_BUCKET=your-published-sites-bucket

# Vertex project/region for Gemini image generation ("Nano Banana").
IMAGE_PROJECT=YOUR_PROJECT
IMAGE_REGION=us-central1
IMAGE_MODEL=gemini-2.5-flash-image

# --- BYOK: per-tenant provider creds (optional — card Azz8fInK) ----------------
# Leave unset and every value above is "managed" (our creds). Set this to a JSON
# object to run a build on a TENANT's own Vertex project / Agent Engine / image
# project (and optionally their Arize Phoenix sink) — same code, their creds.
# Any key omitted falls back to the managed env value above. Bringing model creds
# (agentEngine.resource or image.project) marks the build BYOK for pricing.
# TENANT_PROVIDER_CONFIG={"agentEngine":{"resource":"projects/TENANT/locations/us-central1/reasoningEngines/ID"},"image":{"project":"TENANT"}}

# --- PostHog product analytics + error tracking (optional — card u4xmePAo) -----
# Leave POSTHOG_KEY unset and PostHog is a complete no-op (posthog-js never
# loads, posthog-node never sends) — exactly what a fresh public-repo clone
# should do. Set it to instrument. Use a PROJECT key (phc_…) for an OpsAgents /
# our-products PostHog project — NEVER a personal phx_ key, never committed here.
# The browser ships events to a same-origin opaque path (/rp) that the server
# reverse-proxies to POSTHOG_HOST for ad-blocker survival.
# POSTHOG_KEY=phc_your_project_key
# POSTHOG_HOST=https://us.i.posthog.com

# Optional tuning
# AGENT_ENGINE_TIMEOUT_MS=180000
# AGENT_ENGINE_RUN_BUDGET_MS=540000
# BUILDS_PER_HOUR_PER_IP=12

# --- Sign-in for Publish + My Sites (optional — card VI673sym) -----------------
# Leave all three unset and the app runs fully open (anonymous publish), exactly
# as a fresh clone should. Set all three to gate Publish behind Google sign-in:
# FIREBASE_PROJECT_ID=your-firebase-project
# FIREBASE_API_KEY=your-firebase-web-api-key
# FIREBASE_AUTH_DOMAIN=your-app.web.app
# High-entropy HMAC key for the session cookie (Secret Manager in prod):
# SESSION_SECRET=64-hex-chars
# GCS bucket (private) for visitor photo/video uploads (signed PUT URLs).
# Leave unset to disable the intake drop-zone. Needs: runtime SA with
# storage.objectAdmin on the bucket + iam.serviceAccountTokenCreator on
# itself (keyless V4 signing), and bucket CORS allowing PUT from your origin.
# USER_UPLOADS_BUCKET=your-user-uploads-bucket
# UPLOAD_MAX_IMAGE_MB=15
# UPLOAD_MAX_VIDEO_MB=100
# UPLOADS_PER_HOUR_PER_IP=30
